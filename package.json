{
  "name": "web-video-clip-panel-vue",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter './apps/frontend'",
    "build": "turbo run build --filter './packages/*'",
    "watch": "turbo run watch --filter './packages/*'",
    "newpack": "turbo gen newpack --args",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@turbo/gen": "^2.10.0",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/language-core": "^3.3.5",
    "@vue/tsconfig": "^0.9.1",
    "oxfmt": "^0.56.0",
    "sass-embedded": "^1.100.0",
    "turbo": "^2.10.0",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-dts": "^1.0.3",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.0",
    "vue-tsc": "^3.3.5"
  },
  "packageManager": "bun@1.3.11"
}
